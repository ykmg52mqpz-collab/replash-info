# Formspree endpoint — sign up at https://formspree.io with replash.info@gmail.com
# Create a new form (target email: replash.info@gmail.com), copy the endpoint URL below.
# Without this variable set, the contact form simulates success but does NOT actually send.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/YOUR_FORM_ID
